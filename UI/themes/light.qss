QWidget {
    background-color: #ffffff;
    color: #000000;
    font-size: 13px;
}

QTextEdit {
    background-color: #f5f5f5;
    border: 1px solid #ccc;
}

QLineEdit {
    background-color: #ffffff;
    border: 1px solid #ccc;
    padding: 5px;
}

QPushButton {
    background-color: #e0e0e0;
    border: 1px solid #bbb;
    padding: 6px;
}
